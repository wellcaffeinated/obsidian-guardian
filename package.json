{
  "name": "obsidian-guardian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent vault review: review and accept/revert what agents changed in an Obsidian vault, since the last blessed state.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:plugin": "bash scripts/smoke-plugin.sh",
    "screenshot:plugin": "bash scripts/screenshot-plugin.sh",
    "shot:stub": "bash scripts/shot-stub.sh",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format . --write",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "knip": "^6.5.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
